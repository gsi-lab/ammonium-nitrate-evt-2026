         " ", "\"\<Ratio to sample mean\>\""}], "}"}], ",", "\n", "   ", 
       RowBox[{"{", 
        RowBox[{"U1", ",", " ", "148.65", ",", " ", 
         RowBox[{
          RowBox[{"shadowMean", "[", "U1", "]"}], " ", "//", " ", 
          RowBox[{
           RowBox[{"N", "[", 
            RowBox[{"#", ",", " ", "5"}], "]"}], " ", "&"}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"shadowMean", "[", "U1", "]"}], "/", "101.52"}], " ", "//",
           " ", 
          RowBox[{
