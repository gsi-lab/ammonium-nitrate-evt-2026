        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Xi]", " ", "-", " ", "1"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"yU", "[", "U", "]"}], "^", 
            RowBox[{"(", 
             RowBox[{"1", "/", "\[Xi]"}], ")"}]}], " ", "-", " ", "1"}], 
          ")"}]}], ")"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Comparison", " ", "with", " ", "paper", " ", "values"}], " ", 
    "*)"}], "\n", 
