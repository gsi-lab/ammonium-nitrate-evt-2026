   RowBox[{
    RowBox[{"\[Xi]", " ", "=", " ", "\[Xi]"}], ";", " ", 
    RowBox[{"\[Sigma]", " ", "=", " ", "\[Sigma]"}], ";", " ", 
    RowBox[{"\[Mu]", " ", "=", " ", "\[Mu]"}], ";", " ", 
    RowBox[{"U", " ", "=", " ", "U"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Assumptions", " ", "for", " ", "convergence"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"\[Sigma]", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"U", " ", ">", " ", "\[Mu]"}], " ", "&&", " ", 
      RowBox[{"\[Xi]", " ", "!=", " ", "0"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<=== Step 1: PDF of the Truncated GPD ===\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"fX", "[", "x_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "/", "\[Sigma]"}], ")"}], " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"\[Xi]", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", " ", "-", " ", "\[Mu]"}], ")"}], "/", 
          "\[Sigma]"}]}]}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"1", "/", "\[Xi]"}]}], ")"}]}], ")"}]}]}]}], "\n", 
   RowBox[{
    RowBox[{"FX", "[", "x_", "]"}], " ", ":=", " ", 
    RowBox[{"1", " ", "-", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"\[Xi]", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", " ", "-", " ", "\[Mu]"}], ")"}], "/", 
          "\[Sigma]"}]}]}], ")"}], "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "\[Xi]"}], ")"}]}]}]}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"ftrunc", "[", "x_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"fX", "[", "x", "]"}], " ", "/", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"FX", "[", "U", "]"}], " ", "-", " ", 
         RowBox[{"FX", "[", "\[Mu]", "]"}]}], ")"}]}], " ", "/;", " ", 
      RowBox[{"\[Mu]", " ", "<", " ", "x", " ", "<=", " ", "U"}]}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"fX", "[", "x", "]"}], " ", "//", " ", "TraditionalForm"}], "\n", 
   RowBox[{
    RowBox[{"FX", "[", "x", "]"}], " ", "//", " ", "TraditionalForm"}], "\n", 
   "\n", 
   RowBox[{
    RowBox[{"denom", " ", "=", " ", 
     RowBox[{
      RowBox[{"FX", "[", "U", "]"}], " ", "-", " ", 
      RowBox[{"FX", "[", "\[Mu]", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Denominator FX(U) - FX(\[Mu]) = \>\"", ",", " ", 
      RowBox[{"denom", " ", "//", " ", "TraditionalForm"}]}], "]"}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
