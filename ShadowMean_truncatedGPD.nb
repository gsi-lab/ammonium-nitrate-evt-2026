   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== Step 5-6: Solving the Integrals & Combining ===\
\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"finalE", " ", "=", " ", 
     RowBox[{"Simplify", "[", 
      RowBox[{"numer", " ", "/", " ", "denom"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Step", " ", "7"}], ":", " ", 
     RowBox[{"Final", " ", "expression"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== Step 7: Final Expression for E[X_trunc] (Shadow \
Mean) ===\>\"", "]"}], ";"}], "\n", 
   RowBox[{"finalE", " ", "//", " ", "TraditionalForm"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Optional", ":", " ", 
