   RowBox[{"integrand", " ", "//", " ", "TraditionalForm"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Step", " ", "4"}], ":", " ", 
     RowBox[{"Split", " ", "the", " ", "integral"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== Step 4: Simplification of the Integral ===\>\"",
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"intMu", " ", "=", " ", 
     RowBox[{
      RowBox[{"\[Mu]", "/", "\[Xi]"}], " ", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"y", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "-", " ", 
           RowBox[{"1", "/", "\[Xi]"}]}], ")"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"y", ",", " ", "1", ",", " ", "yU"}], "}"}]}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"intSigma", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Sigma]", "/", 
        RowBox[{"\[Xi]", "^", "2"}]}], ")"}], " ", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", " ", "-", " ", "1"}], ")"}], " ", 
         RowBox[{"y", "^", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], " ", "-", " ", 
            RowBox[{"1", "/", "\[Xi]"}]}], ")"}]}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"y", ",", " ", "1", ",", " ", "yU"}], "}"}]}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"numer", " ", "=", " ", 
     RowBox[{"intMu", " ", "+", " ", "intSigma"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Split integrals:\>\"", "]"}], ";"}], "\n", 
   RowBox[{
