   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== Step 2: Expected Value Calculation ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Etrunc", " ", "=", " ", 
     RowBox[{
      RowBox[{"1", "/", "denom"}], " ", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{"x", " ", 
         RowBox[{"fX", "[", "x", "]"}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "\[Mu]", ",", " ", "U"}], "}"}]}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{"Etrunc", " ", "//", " ", "TraditionalForm"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Step", " ", "3"}], ":", " ", 
      RowBox[{"Substitution", " ", "y"}]}], " ", "=", " ", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"\[Xi]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x", " ", "-", " ", "\[Mu]"}], ")"}], "/", 
        "\[Sigma]"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n=== Step 3: Substitution for Integration ===\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"yU", " ", "=", " ", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"\[Xi]", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"U", " ", "-", " ", "\[Mu]"}], ")"}], "/", 
        "\[Sigma]"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xSub", " ", "=", " ", 
     RowBox[{"\[Mu]", " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Sigma]", "/", "\[Xi]"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"y", " ", "-", " ", "1"}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"integrand", " ", "=", " ", 
     RowBox[{"xSub", " ", "*", " ", 
      RowBox[{"(", 
       RowBox[{"1", "/", "\[Xi]"}], ")"}], " ", 
      RowBox[{"y", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], " ", "-", " ", 
         RowBox[{"1", "/", "\[Xi]"}]}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Integrand after substitution:\>\"", "]"}], 
